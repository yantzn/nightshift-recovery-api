{
  "name": "nightshift-recovery-api",
  "version": "1.0.0",
  "private": true,
  "description": "AWS Lambda backend for nurse night shift recovery support",
  "type": "module",
  "main": "dist/handlers/api.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && tsup src/handlers/api.ts src/local/server.ts --format esm --target node22 --out-dir dist --sourcemap",
    "dev": "tsx watch src/local/server.ts",
    "start": "node dist/local/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1018.0",
    "@aws-sdk/client-secrets-manager": "^3.1018.0",
    "@aws-sdk/lib-dynamodb": "^3.1018.0",
    "@vendia/serverless-express": "^4.12.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/aws-lambda": "^8.10.161",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.2"
  }
}
